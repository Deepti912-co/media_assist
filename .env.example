# For local Vite development, set your Gemini key here.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"


# APP_URL: The URL where this applet is hosted.
# Your hosting platform may inject this at runtime with the deployed service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
